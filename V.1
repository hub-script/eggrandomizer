-- Function to create a styled button
local function createStyledButton(text, parentFrame, onClickFunction)
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, -20, 0, 40) -- Full width minus padding
    button.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    button.TextColor3 = Color3.new(1, 1, 1)
    button.TextScaled = true
    button.Font = Enum.Font.SourceSansBold
    button.Text = text
    button.BorderSizePixel = 0
    button.Parent = parentFrame

    -- Add a UIStroke for a subtle border effect
    local uiStroke = Instance.new("UIStroke")
    uiStroke.Color = Color3.fromRGB(80, 80, 80)
    uiStroke.Thickness = 1
    uiStroke.Parent = button

    button.MouseButton1Click:Connect(onClickFunction)
    return button
end

